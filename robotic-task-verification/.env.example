# Copy this file to .env.local and fill in your values.
# The app works in demo mode without any keys.

# ── Verification (Verify tab) ──────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Email alerts (Live Monitor → Alert Settings) ───────────────────────────
# Free tier: 100 emails/day — https://resend.com
RESEND_API_KEY=re_...

# ── SMS alerts (Live Monitor → Alert Settings) ─────────────────────────────
# Free trial includes credits — https://twilio.com/try-twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...
