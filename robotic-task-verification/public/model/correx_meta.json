  "seq_len": 16,
  "img_size": 224,
  "backbone": "MobileNetV2",
  "clip_dim": 512,
  "gru_hidden": 256,
  "quantized": false,
  "normalization": {
    "mean": [
      0.485,
      0.456,
      0.406
    ],
    "std": [
      0.229,
      0.224,
      0.225
    ]
  }
}