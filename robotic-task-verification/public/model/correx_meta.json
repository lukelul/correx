{
  "model_name": "CorrexVerifier",
  "version": "1.1",
  "input_shape": [
    1,
    16,
    224,
    224,
    3
  ],
  "output_shape": [
    1,
    5
  ],
  "classes": [
    "success",
    "wrong_item",
    "drop_detected",
    "placement_miss",
    "grip_failure"
